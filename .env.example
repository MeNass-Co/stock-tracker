# Discord
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Data Sources
QUIVER_API_KEY=your_quiver_key

# SEC EDGAR
SEC_USER_AGENT=StockTracker your_email@example.com

# Prices
YAHOO_FINANCE_ENABLED=true

# Database
DB_PATH=./data/stocktracker.db

# API Server
API_PORT=3001
API_HOST=127.0.0.1

# Logging
LOG_LEVEL=info

# Polling Intervals (ms)
POLL_EDGAR=300000
POLL_QUIVER=900000
POLL_HOUSE_CLERK=3600000

# Broker (Phase 5)
ALPACA_KEY_ID=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
